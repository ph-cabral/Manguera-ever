generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Personal {
  id        Int      @id @default(autoincrement())
  nombre    String
  dni       String?  @unique  // Opcional: identificación del operario
  activo    Boolean  @default(true)
  cortes    Corte[]  // Relación: un personal hace muchos cortes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Manguera {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique  // ej: "AG-001" (Agua 1/2")
  metros       Int      @default(0)  // metros disponibles
  ubicacion   String?  @default("") // ej: "Estante 3, Depósito A"
  cortes      Corte[]  // Relación: una manguera tiene muchos cortes históricos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([codigo])
}

model Corte {
  id          Int      @id @default(autoincrement())
  metros      Int      // Cuántos metros se cortaron/sacaron
  fecha       DateTime @default(now())
  observacion String?  // Opcional: "Para cliente X", "Urgente", etc.
  
  // Relaciones
  personalId  Int
  personal    Personal @relation(fields: [personalId], references: [id])
  
  mangueraId  Int
  manguera    Manguera @relation(fields: [mangueraId], references: [id])

  @@index([fecha])
  @@index([personalId])
  @@index([mangueraId])
}

