generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Usuario {
  id        Int        @id @default(autoincrement())
  nombre    String     
  registros Manguera[] // Un usuario tiene muchas mangueras
  createdAt DateTime   @default(now())
}

model Manguera {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique  // ← Volvé a agregar @unique si querés evitar duplicados
  metros      Int       
  ubicacion   String?   
  usuarioId   Int       
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // CAMPO DE RELACIÓN QUE TE FALTA:
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  
  @@index([codigo])
  @@index([usuarioId])
}
